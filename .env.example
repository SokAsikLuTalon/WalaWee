# Server (Railway / local backend)
DATABASE_URL=postgresql://user:password@host:port/database
SESSION_SECRET=your-session-secret-min-32-chars
TEMANQRIS_API_KEY=your_temanqris_api_key
TEMANQRIS_WEBHOOK_SECRET=your_webhook_secret
DISCORD_API_SECRET=your_discord_bot_secret

# Optional: for production CORS and cookies (e.g. https://your-app.up.railway.app)
FRONTEND_ORIGIN=https://your-app.up.railway.app

# Frontend (only if API is on different origin; leave empty if same origin)
# VITE_API_URL=https://your-app.up.railway.app
